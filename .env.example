# Minimum required before first deploy
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/lecertify?sslmode=require"
NEXTAUTH_SECRET="replace-with-random-32-byte-secret"
CERT_ENCRYPTION_KEY_BASE64="replace-with-32-byte-base64-key"

# Recommended for production URL. Vercel can auto-detect, but set this for Netlify/self-hosted.
NEXTAUTH_URL="http://localhost:3000"

# First setup option. Set false, deploy, browse /setup, then enable Entra ID in UI.
LECERTIFY_SETUP_MODE="true"
SETUP_ADMIN_PASSWORD="change-this-temporary-password"
