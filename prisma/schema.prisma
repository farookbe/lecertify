generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

enum CertificateStatus { DRAFT PENDING ISSUED FAILED EXPIRING REVOKED }
enum UserRole { VIEWER OPERATOR ADMIN }

model User { id String @id @default(cuid()) email String @unique name String? role UserRole @default(VIEWER) createdAt DateTime @default(now()) audits AuditLog[] }
model AppSetting { key String @id value String secret Boolean @default(false) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model Certificate { id String @id @default(cuid()) commonName String subjectAltNames String[] friendlyName String? status CertificateStatus @default(DRAFT) caDirectoryUrl String useCnameDelegation Boolean @default(true) challengeRecord String? cnameTarget String? notBefore DateTime? notAfter DateTime? issuer String? serialNumber String? thumbprint String? encryptedPrivateKey String? encryptedCertPem String? encryptedChainPem String? lastError String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt jobs CertificateJob[] }
model CertificateJob { id String @id @default(cuid()) certificateId String certificate Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade) type String status CertificateStatus @default(PENDING) output String? createdAt DateTime @default(now()) completedAt DateTime? }
model AuditLog { id String @id @default(cuid()) actorId String? actor User? @relation(fields: [actorId], references: [id]) action String target String? metadata Json? createdAt DateTime @default(now()) }
